# ─── Base de données pipeline ──────────────────────────────────────────────────
# Copiez ce fichier en .env et remplissez les valeurs réelles
DB_HOST=localhost       # 'postgres' si lancé via Docker Compose
DB_PORT=5432
DB_NAME=afrihealth
DB_USER=postgres
DB_PASSWORD=yourpassword

# ─── Airflow (optionnel si vous modifiez docker-compose.yml) ───────────────────
# Les valeurs ci-dessous sont reprises dans docker-compose.yml via ${...}
# Aucune action requise si vous utilisez les valeurs par défaut
